{
  "name": "ecocampus-recording",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "playwright install chromium",
    "record:messages": "node ./record-online-message.mjs",
    "record:flows": "node ./record-online-flows.mjs --scenario=all",
    "check": "node --check ./record-online-message.mjs && node --check ./lib/recording-kit.mjs && node --check ./record-online-flows.mjs"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.61.1"
  }
}
