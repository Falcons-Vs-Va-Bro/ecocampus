DB_URL=jdbc:mysql://127.0.0.1:3306/ecocampus?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USERNAME=ecocampus
DB_PASSWORD=replace-with-a-long-random-password
DB_POOL_MAX_SIZE=12
DB_POOL_MIN_IDLE=3
DB_POOL_CONNECTION_TIMEOUT_MS=10000
JWT_SECRET=replace-with-at-least-32-random-bytes
CORS_ALLOWED_ORIGIN_PATTERNS=https://ecocampus.teamdsb.online
FILE_STORAGE_LOCAL_DIR=/opt/ecocampus/storage/uploads
FILE_STORAGE_PUBLIC_URL_PREFIX=/uploads
# 填本机的 Tailscale IPv4；不要填 0.0.0.0，也不要绑定公网网卡。
SERVER_ADDRESS=100.x.y.z
SERVER_THREADS_MAX=100
SERVER_THREADS_MIN_SPARE=8
SERVER_MAX_CONNECTIONS=300
SERVER_ACCEPT_COUNT=100
SPRINGDOC_ENABLED=false
